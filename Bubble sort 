import java.util.Arrays;

public class BubbleSort{

    static void bubbleSort(int[] arr) {
        int n = arr.length;
        for (int i = 0; i < n - 1; i++) { // Outer loop controls the number of passes
            for (int j = 0; j < n - i - 1; j++) { // Inner loop for comparisons and swaps
                // Compare adjacent elements and swap if they are in the wrong order
                if (arr[j] > arr[j + 1]) {
                    // Swap arr[j+1] and arr[j] using a temporary variable
                    int temp = arr[j];
                    arr[j] = arr[j + 1];
                    arr[j + 1] = temp;
                }
            }
        }
    }

    public static void main(String[] args) {
        int[] arr = {64, 34, 25, 12, 22, 11, 90};
        System.out.println("Unsorted array: " + Arrays.toString(arr));

        bubbleSort(arr); // Call the bubble sort method

        System.out.println("Sorted array: " + Arrays.toString(arr));
    }
}
