import java.util.ArrayList;
import java.util.LinkedList;
import java.util.Queue;
import java.util.HashSet;
import java.util.Set; 

public class BFSExample {

    // Function to perform Breadth-First Search
    public void bfs(ArrayList<ArrayList<Integer>> adj, int startNode) {
        // Queue to store nodes to be visited (FIFO)
        Queue<Integer> queue = new LinkedList<>();
        // Set to keep track of visited nodes to prevent cycles
        Set<Integer> visited = new HashSet<>();

        // Start BFS from the initial node
        queue.add(startNode);
        visited.add(startNode);

        while (!queue.isEmpty()) {
            // Dequeue a node from the queue and print it (or process)
            int currentNode = queue.poll();
            System.out.print(currentNode + " ");

            // Get all adjacent nodes of the dequeued node
            for (int neighbor : adj.get(currentNode)) {
                // If a neighbor has not been visited, mark it as visited and enqueue it
                if (!visited.contains(neighbor)) {
                    visited.add(neighbor);
                    queue.add(neighbor);
                }
            }
        }
    }

    public static void main(String[] args) {
        // Example Graph (undirected) represented using an adjacency list
        // 0: [1, 2]
        // 1: [0, 2, 3]
        // 2: [0, 1, 4]
        // 3: [1, 4]
        // 4: [2, 3]
        
        int V = 5; // Number of vertices
        ArrayList<ArrayList<Integer>> adj = new ArrayList<>(V);

        for (int i = 0; i < V; i++) {
            adj.add(new ArrayList<>());
        }

        // Add edges to the graph
        addEdge(adj, 0, 1);
        addEdge(adj, 0, 2);
        addEdge(adj, 1, 2);
        addEdge(adj, 1, 3);
        addEdge(adj, 2, 4);
        addEdge(adj, 3, 4);

        System.out.println("Breadth-First Traversal starting from vertex 0:");
        BFSExample bfsObj = new BFSExample();
        bfsObj.bfs(adj, 0); // Expected output: 0 1 2 3 4
    }

    // Utility function to add an edge in an undirected graph
    static void addEdge(ArrayList<ArrayList<Integer>> adj, int u, int v) {
        adj.get(u).add(v);
        adj.get(v).add(u); 
    }
}
